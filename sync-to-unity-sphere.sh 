#!/bin/bash
# ================================================
# PiRC → project-unity-sphere PROFESSIONAL SYNC v4.0
# Automatic Bidirectional Orchestrator
# ================================================

set -euo pipefail

echo "🚀 Starting Professional PiRC → Unity Sphere Sync..."

WORKSPACE="$HOME/PiRC_Ecosystem"
UNITY_DIR="$HOME/project-unity-sphere"
UNITY_REPO="https://github.com/Ze0ro99/project-unity-sphere.git"

# 1. Clone or update Unity Sphere repo
if [ ! -d "$UNITY_DIR" ]; then
    echo "Cloning project-unity-sphere..."
    git clone "$UNITY_REPO" "$UNITY_DIR"
else
    echo "Updating project-unity-sphere..."
    cd "$UNITY_DIR" && git pull origin main || true
fi
cd "$UNITY_DIR"

# 2. Make repository Public
echo "Making repository Public..."
gh repo edit Ze0ro99/project-unity-sphere --visibility public 2>/dev/null || echo "→ Please set Public manually in GitHub Settings"

# 3. Create necessary directories
mkdir -p src/config packages docs

# 4. Smart Sync from PiRC (Main Source of Truth)
echo "Syncing latest structure from PiRC..."
rsync -av --delete \
    --exclude='.git' \
    --exclude='target/' \
    --exclude='node_modules/' \
    "$WORKSPACE/apps/frontend/" ./

rsync -av --delete \
    --exclude='.git' \
    "$WORKSPACE/packages/" ./packages/ 2>/dev/null || true

rsync -av --delete \
    --exclude='.git' \
    "$WORKSPACE/docs/" ./docs/ 2>/dev/null || true

# 5. Update API Configuration
cat > src/config/api.ts << 'EOF'
export const API_CONFIG = {
  PI_TESTNET_RPC: "https://rpc.testnet.minepi.com",
  PI_MAINNET_RPC: "https://rpc.mainnet.minepi.com",
  SOROBAN_RPC: "https://soroban-rpc.testnet.stellar.org",
  PIDEX_TESTNET: "https://pidex.testnet.minepi.com",
  BASE_URL: "https://project-unity-sphere.lovable.app",
  VERSION: "3.2.0",
  SYNC_MODE: "bidirectional",
  LAST_SYNC: "$(date '+%Y-%m-%d %H:%M:%S')"
};

export default API_CONFIG;
EOF

# 6. Final Commit & Push
git add .
git commit -m "chore: auto-sync from PiRC Core - $(date '+%Y-%m-%d %H:%M:%S UTC')" || echo "No new changes to commit"
git push origin main --force-with-lease

echo ""
echo "✅ SYNC COMPLETED SUCCESSFULLY!"
echo "🌐 Repository: https://github.com/Ze0ro99/project-unity-sphere"
echo "📱 Live App: https://project-unity-sphere.lovable.app"
echo "🔄 Future updates: Run this script again or use GitHub Actions"
echo ""
