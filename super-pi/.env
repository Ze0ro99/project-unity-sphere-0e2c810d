# Database (Production Grade)
DB_PASSWORD=PiSuperSecure314159_v4_$(openssl rand -base64 32 | tr -d "=+/" | cut -c1-32)

# JWT & Security
JWT_SECRET=pi_jwt_v4_$(openssl rand -hex 64)
WALLET_SECRET=pi_wallet_v4_$(openssl rand -hex 64)
ENCRYPTION_KEY=pi_encrypt_v4_$(openssl rand -hex 32)
PARTNER_API_KEY=partner_v4_$(openssl rand -hex 32)

# Stablecoin (FIXED)
PI_STABLECOIN_VALUE=314159
PI_STABLECOIN_NAME="Pure Pi Stablecoin"

# External APIs
EXCHANGE_DB_URL=https://api.blockcypher.com/v1
EXCHANGE_ORACLE_URLS="https://api.binance.com/api/v3/ticker/price?symbol=PIUSDT,https://api.coingecko.com/api/v3/simple/price?ids=pi-network&vs_currencies=usd"
ETHERSCAN_API_KEY=your_etherscan_key_here

# Monitoring
GRAFANA_PASSWORD=MY_SECRET_KEY

# CDN & Partners
CDN_BASE_URL=https://cdn.pi.ecosystem
