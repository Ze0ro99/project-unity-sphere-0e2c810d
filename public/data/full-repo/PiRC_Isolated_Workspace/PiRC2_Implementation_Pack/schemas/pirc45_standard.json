{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PiRC-45 Transaction Metadata",
  "type": "object",
  "properties": {
    "version": { "type": "string", "enum": ["45.1"] },
    "app_id": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "memo_id": { "type": "string", "maxLength": 128 },
        "integrity_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "type": { "type": "string", "enum": ["goods", "services", "transfer"] }
      },
      "required": ["memo_id", "integrity_hash", "type"]
    }
  },
  "required": ["version", "app_id", "payload"]
}

