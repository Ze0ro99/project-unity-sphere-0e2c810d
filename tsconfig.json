{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "Cargo.lock",
    "target",
    "PiRC_Isolated_Workspace",
    "PiRC_Master_Workspace",
    "PiRC1",
    "PiRC2_Implementation_Pack",
    "Omni_Sovereign_Architecture",
    "PiRC-101",
    "PiRC-202",
    "PiRC-203",
    "PiRC-204",
    "PiRC-205",
    "PiRC-206",
    "PiRC2",
    "PIRC",
    "SmartContracts",
    "contracts",
    "src",
    "scripts",
    "simulator",
    "simulations",
    "archive",
    "docs",
    "audit",
    "deployment",
    "deployment_logs",
    "deployment_reports",
    "ecosystem_data",
    "examples",
    "rwa_verify",
    "sovereign_market",
    "sovereign_ecosystem",
    "metrics",
    "tests",
    "spec",
    "schemas",
    "data",
    "downloads",
    "results",
    "integration",
    "core",
    "automation",
    "configs",
    "diagrams",
    "developer_hub",
    "github",
    "lib/pi_sdk",
    "PiRC_divine_justice",
    "ops",
    "security",
    "Public",
    "assets",
    "images",
    "frontend",
    "backend",
    "netlify/functions/**/*.js",
    "api/main.py"
  ]
}
