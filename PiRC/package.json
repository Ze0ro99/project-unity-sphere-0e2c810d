{
  "name": "pirc-ecosystem-v3",
  "version": "3.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "contracts/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:contracts": "cargo build --target wasm32-unknown-unknown --release",
    "build:all": "npm run build:frontend && npm run build:contracts",
    "dev:frontend": "npm run dev --workspace=apps/frontend"
  }
}
