# PiRC Sovereign Master Orchestrator – Environment Configuration
# Copy this file to `.env` and fill in your credentials.
# NEVER commit `.env`. NEVER paste real secrets into source files, logs, or PR descriptions.

# ----- Network selection -----
NETWORK=TESTNET                    # TESTNET | MAINNET (orchestrator refuses MAINNET writes by default)

# ----- Stellar / Soroban (Pi Testnet uses Soroban RPC) -----
# Secret seed used to sign Soroban / Stellar transactions. Must start with `S`.
STELLAR_TESTNET_SECRET=
STELLAR_HORIZON_URL=https://api.testnet.minepi.com
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443

# ----- Pi Network -----
PI_API_KEY=
PI_NETWORK_RPC_URL=https://rpc.testnet.minepi.com
PINETWORK_SDK_LIVE=true

# ----- SmartContracts factory sync -----
# Token used to pull released artifacts from the SmartContracts repo.
OMNI_SYNC_TOKEN=

# ----- Public on-chain identifiers (NOT secrets, safe to commit) -----
# Master Issuer for the 7 colored Project Packets (Stellar G-address):
PIRC_MASTER_ISSUER=GA3ECRFJ6SO5BW6NEIKW3ACJXNG5UNBTLRRXWC742NHUEDV6KL3RNEN6
# PiRC2 Subscription smart contract (Soroban C-address) for recurring payments:
PIRC2_SUBSCRIPTION_CONTRACT=CCUF75B6W3HRJTJD6O7OXNI72HGJ7DERZ5MUNOMFMSK23ME5GUIKPFYV
