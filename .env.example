# ─── PiRC Sovereign Platform — Environment Variables ───────────────────────────
# Copy this file to .env (for local development) or configure in Vercel / Replit.
# Variables prefixed with VITE_ are bundled into the client-side SPA.
# All other variables are server-only and MUST NOT be exposed to the browser.
# ────────────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────────────
# Port the Express server listens on.
# Replit sets $PORT automatically; Vercel uses its own routing (value ignored).
PORT=3000

# Node environment. Set to "production" on Vercel / deployment targets.
NODE_ENV=development

# ── GitHub Integration (server-side only — NEVER prefix with VITE_) ─────────────
# Personal Access Token with read access to Ze0ro99/PiRC.
# Required for Repository Sync, webhook validation, and file import features.
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to validate incoming GitHub webhook payloads (HMAC-SHA256).
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=replace_with_random_secret

# ── Pi Network (server-side only) ───────────────────────────────────────────────
# Server API key issued by Pi Network Developer Portal.
# Required for payment approve/complete endpoints.
PI_NETWORK_API_KEY=replace_with_pi_api_key

# Base URL for Pi Network API. Override to use testnet during development.
# Testnet:  https://api.testnet.minepi.com
# Mainnet:  https://api.minepi.com
PI_NETWORK_API_URL=https://api.testnet.minepi.com

# ── Pi Network (client-side — safe to expose) ────────────────────────────────────
# Your Pi App ID from the Pi Developer Portal.
VITE_PI_APP_ID=pirc-sovereign

# Set to "true" to run Pi SDK in sandbox/testnet mode.
VITE_PI_SANDBOX=true

# Current deployment environment label shown in the UI.
# Values: development | staging | production
VITE_APP_ENV=development

# ── CORS (optional) ─────────────────────────────────────────────────────────────
# Additional origin to whitelist for CORS (e.g. a custom domain).
# The following are always allowed: *.vercel.app, *.lovable.app, *.replit.dev
ALLOWED_ORIGIN=

# ── Google Gemini (optional — AI Studio compatibility) ───────────────────────────
GEMINI_API_KEY=
