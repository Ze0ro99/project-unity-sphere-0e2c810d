# PiRC Backend Environment Configuration - Staging
# Copy this file to .env and populate with actual values

# Server Configuration
NODE_ENV=staging
PORT=3001

# Webhook Security
# Generate with: openssl rand -hex 32
# Store securely in Vercel Environment Variables as LOVABLE_WEBHOOK_SECRET
LOVABLE_WEBHOOK_SECRET=your_32_byte_hex_string_here

# Soroban RPC Endpoint (Testnet or Mainnet)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Master Registry Contract Address
MASTER_REGISTRY_ADDRESS=your_contract_address_here

# Dashboard Endpoint
LOVABLE_DASHBOARD_URL=https://project-unity-sphere.lovable.app

# Logging Level
LOG_LEVEL=debug
